# ============================================================
# ArkAge environment variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.
# Production env vars live in Vercel; pull with `vercel env pull .env.local`.

# --- Network: Arc Testnet (per spec §1.3) ---
ARC_TESTNET_RPC_HTTP=https://rpc.testnet.arc.network
ARC_TESTNET_RPC_WS=wss://rpc.testnet.arc.network

# --- Database: Neon Postgres (provisioned in Plan A Task 21) ---
# Use the pooled connection string for runtime; direct for migrations.
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# --- Circle (DCW + Contract Platform webhook) ---
# Get from https://console.circle.com — Plan A Task 25 (wallets) and Task 28 (webhook).
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WEBHOOK_SECRET=

# --- Goldsky (optional in dev — Plan A Task 27) ---
GOLDSKY_PROJECT_ID=

# --- Pinned ArkAge contract addresses (set after Plan A Task 26 deploy) ---
ARKAGE_HOOK_COMPOSER_ADDRESS=
ARKAGE_REPUTATION_HOOK_ADDRESS=
ARKAGE_POLICY_HOOK_ADDRESS=
ARKAGE_EVALUATOR_FEE_HOOK_ADDRESS=
ARKAGE_AGENT_REGISTRY_ADDRESS=

# --- Tier 3 system wallets (set after Plan A Task 25 provisioning) ---
ARKAGE_VALIDATOR_WALLET_ADDRESS=
ARKAGE_TREASURY_WALLET_ADDRESS=
ARKAGE_GAS_FUNDER_WALLET_ADDRESS=

# --- Cron auth (Vercel) ---
# Generate locally with: openssl rand -hex 32
CRON_SECRET=
