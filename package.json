{
  "name": "arkage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "dotenv -e .env.local -- vitest run",
    "test:watch": "dotenv -e .env.local -- vitest",
    "test:coverage": "dotenv -e .env.local -- vitest run --coverage",
    "test:workflow": "dotenv -e .env.local -- vitest run --config vitest.workflow.config.ts",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:reset": "dotenv -e .env.local -- prisma migrate reset",
    "db:seed": "dotenv -e .env.local -- prisma db seed",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:format": "dotenv -e .env.local -- prisma format",
    "bootstrap:tier3": "dotenv -e .env.local -- tsx scripts/bootstrap-tier3-wallets.ts"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^10.3.1",
    "@circle-fin/modular-wallets-core": "^1.0.13",
    "@circle-fin/x402-batching": "^3.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/blob": "^2.3.3",
    "@workflow/ai": "^4.1.2",
    "@workflow/next": "^4.0.5",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "viem": "^2.48.8",
    "workflow": "^4.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/config": "^0.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@workflow/vitest": "^4.0.5",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
